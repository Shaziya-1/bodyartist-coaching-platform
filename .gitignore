# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment this out if you decide to check in your .python-version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you do not want it, uncomment the following line.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be checked in.
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally recommended to be checked in.
.pdm-plugins/
.pdm-build/

# PEP 582; ES modules style packages for Python
__pypackages__/

# Celery stuff
